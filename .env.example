# LLM backend (OpenAI-compatible API)
# Default: Ollama at localhost:11434
# For llama.cpp:   http://localhost:8080/v1
# For NIM:         https://integrate.api.nvidia.com/v1 (set API key below)
# For OpenAI:      https://api.openai.com/v1  (set API key below)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=mistral

# Optional: API key for LLM provider (required for OpenAI, NIM; not for Ollama, llama.cpp)
# API_KEY=sk-...

# Logging level
LOG_LEVEL=INFO

# Minimum relevance score (0-3 integer scale) to include a finding
# 0 = nothing to do with the query
# 1 = seems related but no answer
# 2 = partial or complete answer (may be unclear or hidden)
# 3 = dedicated to the query with a partial or complete answer
RELEVANCE_THRESHOLD=2

# Maximum results per arXiv API call (default: 15 — each sub-task runs two queries:
# one title-only and one all-fields, then merges results before dedup)
ARXIV_MAX_RESULTS=15

# Docker: UID/GID for file ownership on bind-mounted directories (default: 1000:1000)
UID=1000
GID=1000
